generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum MessageType {
  text
  image
  document
  audio
  template
}

enum MessageStatus {
  pending
  sent
  delivered
  read
  failed
}

enum MessageDirection {
  inbound
  outbound
}

enum CampaignStatus {
  draft
  scheduled
  running
  completed
  failed
}

enum UserRole {
  OWNER
  FULL_ACCESS
  CHAT_ONLY
}

enum PlanTier {
  free
  starter
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

// ✅ جديد: حالة رسالة الـ Queue
enum QueueStatus {
  pending      // في الانتظار
  processing   // جاري المعالجة (محجوز)
  sent         // تم الإرسال
  failed       // فشل نهائي (استنفذ المحاولات)
  cancelled    // ألغاه المستخدم
}



model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  phone    String?
  password String
  image    String?
  apiKey   String? @unique

  role        UserRole @default(OWNER)
  workspaceId String?
  inviteCode  String?  @unique
  parentId    String?

  parent  User?  @relation("TeamHierarchy", fields: [parentId], references: [id])
  members User[] @relation("TeamHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappAccount WhatsAppAccount?
  subscription    Subscription?

  contacts      Contact[]
  audiences     Audience[]
  templates     Template[]
  campaigns     Campaign[]
  messages      Message[]
  messageQueues MessageQueue[]

  @@index([email])
  @@index([workspaceId])
  @@index([parentId])
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   PlanTier           @default(free)
  status SubscriptionStatus @default(active)

  campaignsUsedThisMonth Int      @default(0)
  periodResetAt          DateTime @default(now())
  currentPeriodStart     DateTime @default(now())
  currentPeriodEnd       DateTime @default(dbgenerated("NOW() + INTERVAL '100 years'"))

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([plan])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model WhatsAppAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken   String @db.Text
  phoneNumberId String
  wabaId        String @unique

  // ✅ جديد: تتبع الـ Tier الخاص بكل رقم
  messagingTier  Int      @default(1)    // 1=1K, 2=10K, 3=100K, 4=unlimited
  dailySentCount Int      @default(0)    // عداد يومي
  dailyResetAt   DateTime @default(now()) // آخر تصفير

  // ✅ جديد: backoff state لو Meta رجعت 429
  backoffUntil   DateTime? // النظام ينتظر لحد الوقت ده
  backoffCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageQueues MessageQueue[]
}

// ✅ جديد: جدول الـ Queue الرئيسي
model MessageQueue {
  id String @id @default(cuid())

  // ─ مين صاحب الرسالة
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ─ Credentials (نسخة وقت الإنشاء — مش بتتغير لو العميل بدّل التوكن)
  whatsappAccountId String
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  phoneNumberId     String          // نسخة للفرز السريع بدون join
  accessTokenSnap   String          @db.Text // snapshot من التوكن وقت الإنشاء

  // ─ المستقبل
  toPhone   String
  contactId String?

  // ─ المحتوى
  messageType  String  @default("template") // template | text
  templateName String?
  templateLang String  @default("ar")
  templateVars Json?   // متغيرات القالب لو فيه
  content      String? @db.Text             // للرسائل النصية العادية

  // ─ ربط الحملة
  campaignId String?

  // ─ Queue Control
  status      QueueStatus @default(pending)
  scheduledAt DateTime    @default(now())  // موعد الإرسال المطلوب
  processedAt DateTime?                     // وقت المعالجة الفعلي
  sentAt      DateTime?

  attempts    Int  @default(0)
  maxAttempts Int  @default(3)
  nextRetryAt DateTime?

  // ─ النتيجة
  whatsappMsgId String? // ID اللي رجعته Meta بعد الإرسال
  error         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─ الـ Indexes الحرجة للأداء
  @@index([status, scheduledAt])           // الأهم: للـ cron يجيب الـ pending
  @@index([phoneNumberId, status])         // للـ rate limiting per number
  @@index([campaignId])                    // لتتبع الحملة
  @@index([userId, status])               // لعرض رسائل اليوزر
  @@index([status, nextRetryAt])           // للـ retry logic
}

model Audience {
  id   String @id @default(cuid())
  name String
  type String @default("excel")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id    String  @id @default(cuid())
  phone String
  name  String?
  notes String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  audienceId String?
  audience   Audience? @relation(fields: [audienceId], references: [id], onDelete: SetNull)

  messages Message[]

  isPinned   Boolean @default(false)
  isArchived Boolean @default(false)
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, userId])
  @@index([userId])
  @@index([phone])
  @@index([lastMessageAt])
}

model Template {
  id      String @id @default(cuid())
  metaId  String
  name    String
  content String @db.Text

  language String @default("ar")
  category String @default("MARKETING")
  status   String @default("pending")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([metaId, userId])
  @@index([userId])
  @@index([status])
}

model Campaign {
  id     String         @id @default(cuid())
  name   String
  status CampaignStatus @default(draft)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  messages Message[]

  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  failedCount    Int @default(0)

  // ✅ جديد: تتبع الـ Queue
  totalQueued    Int @default(0)  // إجمالي اللي اتحط في الـ queue
  queuedCount    Int @default(0)  // لسه في الانتظار

  startedAt   DateTime?
  completedAt DateTime?
  scheduledAt DateTime? @map("scheduled_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt]) // للـ cron يجيب الـ scheduled campaigns
}

model Message {
  id String @id @default(cuid())

  content String? @db.Text

  type      MessageType      @default(text)
  status    MessageStatus    @default(pending)
  direction MessageDirection @default(outbound)

  whatsappId String? @unique

  mediaUrl String? @db.Text
  error    String?

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@index([contactId, createdAt])
}

model WebhookLog {
  id String @id @default(cuid())

  userId String?

  payload   String  @db.Text
  processed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([processed])
  @@index([createdAt])
}
