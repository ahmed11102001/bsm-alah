generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  password  String
  image     String?
  apiKey String? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappAccount WhatsAppAccount?
  campaigns       Campaign[]
  audiences       Audience[]
  templates       Template[]
  messages        Message[]
  contacts        Contact[]

  @@index([email])
}

model WhatsAppAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken   String   @db.Text
  phoneNumberId String
  wabaId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Audience {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  Contact[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id           String    @id @default(cuid())
  phone        String
  name         String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audienceId   String?
  audience     Audience? @relation(fields: [audienceId], references: [id], onDelete: SetNull)
  messages     Message[]
  
  // الإضافات الجديدة للشات 👇
  notes        String?   @db.Text    // لحفظ الملاحظات اللي في الـ Sidebar اليمين
  isPinned     Boolean   @default(false) // لتثبيت المحادثة فوق
  isArchived   Boolean   @default(false) // لأرشفة المحادثة
  lastMessageAt DateTime @default(now()) // مهم جداً لترتيب المحادثات من الأحدث للأقدم

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([phone, audienceId], name: "phone_audienceId")
  @@index([userId])
  @@index([phone])
  @@index([lastMessageAt]) // تسريع الترتيب
}

model Campaign {
  id             String   @id @default(cuid())
  name           String
  status         String   @default("draft")
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId     String?
  template       Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sentCount      Int      @default(0)
  deliveredCount Int      @default(0)
  readCount      Int      @default(0)
  failedCount    Int      @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  messages       Message[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model Template {
  id        String   @id @default(cuid())
  metaId    String
  name      String
  content   String   @db.Text
  language  String   @default("ar") 
  category  String   @default("MARKETING")
  status    String   @default("pending")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([metaId, userId])
  @@index([userId])
}

model Message {
  id          String    @id @default(cuid())
  content     String?   @db.Text
  type        String    @default("text") // text, image, document, template, audio
  direction   String    @default("outbound")
  status      String    @default("pending") // sent, delivered, read, failed
  whatsappId  String?   @unique
  
  // الإضافات الجديدة للشات 👇
  mediaUrl    String?   @db.Text    // رابط الصورة أو الملف لو الرسالة مش نصية
  replyToId   String?               // لو الرسالة رد على رسالة تانية
  
  error       String?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([createdAt]) // تسريع جلب تاريخ المحادثة
}
model WebhookLog {
  id        String   @id @default(cuid())
  payload   String   @db.Text
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([processed])
}