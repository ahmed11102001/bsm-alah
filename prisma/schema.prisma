generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  phone            String?
  password         String
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  apiKey           String?           @unique
  role             UserRole          @default(OWNER)
  inviteCode       String?           @unique
  parentId         String?
  workspaceId      String?
  isSuper          Boolean           @default(false)
  deletedAt        DateTime?
  deletedBy        String?
  brandName        String?
  businessDesc     String?
  productsInfo     String?
  pricingInfo      String?
  workingHours     String?
  aiTone           String            @default("friendly")
  aiAgent          AIAgent?
  audiences        Audience[]
  automationRules  AutomationRule[]
  campaigns        Campaign[]
  contacts         Contact[]
  easyOrdersStore  EasyOrdersStore?
  wooCommerceStore WooCommerceStore?
  messages         Message[]
  messageQueues    MessageQueue[]
  notifications    Notification[]
  shopifyStore     ShopifyStore?
  storeAutomations StoreAutomation[]
  storeOrders      StoreOrder[]
  subscription     Subscription?
  templates        Template[]
  trackedClicks    TrackedClick[]
  parent           User?             @relation("TeamHierarchy", fields: [parentId], references: [id])
  members          User[]            @relation("TeamHierarchy")
  whatsappAccount  WhatsAppAccount?

  @@index([email])
  @@index([workspaceId])
  @@index([parentId])
  @@index([deletedAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  plan                   PlanTier           @default(free)
  status                 SubscriptionStatus @default(active)
  isBetaUser             Boolean            @default(false)
  campaignsUsedThisMonth Int                @default(0)
  periodResetAt          DateTime           @default(now())
  currentPeriodStart     DateTime           @default(now())
  currentPeriodEnd       DateTime           @default(dbgenerated("(now() + '100 years'::interval)"))
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([plan])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model WhatsAppAccount {
  id             String         @id @default(cuid())
  userId         String         @unique
  accessToken    String
  phoneNumberId  String
  wabaId         String         @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  backoffCount   Int            @default(0)
  backoffUntil   DateTime?
  dailyResetAt   DateTime       @default(now())
  dailySentCount Int            @default(0)
  messagingTier  Int            @default(1)
  messageQueues  MessageQueue[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MessageQueue {
  id                String          @id @default(cuid())
  userId            String
  whatsappAccountId String
  phoneNumberId     String
  toPhone           String
  contactId         String?
  messageType       String          @default("template")
  templateName      String?
  templateLang      String          @default("ar")
  templateVars      Json?
  content           String?
  campaignId        String?
  status            QueueStatus     @default(pending)
  scheduledAt       DateTime        @default(now())
  processedAt       DateTime?
  sentAt            DateTime?
  attempts          Int             @default(0)
  maxAttempts       Int             @default(3)
  nextRetryAt       DateTime?
  whatsappMsgId     String?
  error             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  existingMessageId String?
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([phoneNumberId, status])
  @@index([campaignId])
  @@index([userId, status])
  @@index([status, nextRetryAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  link      String?
  meta      Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model Audience {
  id        String    @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  type      String    @default("excel")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  Contact[]

  @@index([userId])
}

model Contact {
  id                String    @id @default(cuid())
  phone             String
  audienceId        String?
  createdAt         DateTime  @default(now())
  name              String?
  userId            String
  deletedAt         DateTime?
  isArchived        Boolean   @default(false)
  isPinned          Boolean   @default(false)
  lastMessageAt     DateTime?
  notes             String?
  unreadCount       Int       @default(0)
  updatedAt         DateTime  @updatedAt
  voiceAgentEnabled Boolean   @default(false)
  audience          Audience? @relation(fields: [audienceId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@unique([phone, userId])
  @@index([userId])
  @@index([phone])
  @@index([lastMessageAt])
}

model Template {
  id               String            @id @default(cuid())
  name             String
  content          String
  status           String            @default("pending")
  userId           String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  metaId           String
  category         String            @default("MARKETING")
  language         String            @default("ar")
  automationRules  AutomationRule[]
  campaigns        Campaign[]
  storeAutomations StoreAutomation[]
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([metaId, userId])
  @@index([userId])
  @@index([status])
}

model Campaign {
  id             String          @id @default(cuid())
  name           String
  userId         String
  templateId     String?
  sentCount      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  completedAt    DateTime?
  deliveredCount Int             @default(0)
  failedCount    Int             @default(0)
  readCount      Int             @default(0)
  startedAt      DateTime?
  status         CampaignStatus  @default(draft)
  scheduledAt    DateTime?       @map("scheduled_at")
  queuedCount    Int             @default(0)
  totalQueued    Int             @default(0)
  ordersCount    Int             @default(0)
  revenue        Float           @default(0)
  trackedUrl     String?
  template       Template?       @relation(fields: [templateId], references: [id])
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignOrders CampaignOrder[]
  messages       Message[]

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model Message {
  id          String           @id @default(cuid())
  content     String?
  userId      String
  campaignId  String?
  contactId   String
  whatsappId  String?          @unique
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?
  deliveredAt DateTime?
  error       String?
  mediaUrl    String?
  readAt      DateTime?
  sentAt      DateTime?
  type        MessageType      @default(text)
  updatedAt   DateTime         @updatedAt
  status      MessageStatus    @default(pending)
  direction   MessageDirection @default(outbound)
  reactions   Json?            @default("[]")
  campaign    Campaign?        @relation(fields: [campaignId], references: [id])
  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contactId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@index([contactId, createdAt])
}

model WebhookLog {
  id        String   @id @default(cuid())
  payload   String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String?

  @@index([processed])
  @@index([createdAt])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  brandName String
  phone     String
  rating    Int
  content   String
  approved  Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
  @@index([createdAt])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percent")
  discountValue Float
  maxUses       Int       @default(1)
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([code])
  @@index([active])
}

// ─── ShopifyStore — webhook-only, no OAuth, no custom app ────────────────────
model ShopifyStore {
  id          String            @id @default(cuid())
  userId      String            @unique
  shop        String            @unique  // myshopify.com domain — verified
  storeName   String                     // اسم العرض اللي بيختاره المستخدم
  accessToken String?
  scope       String?
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  automations StoreAutomation[]
  orders      StoreOrder[]
}

model EasyOrdersStore {
  id            String            @id @default(cuid())
  userId        String            @unique
  storeName     String
  apiKey        String
  webhookSecret String
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  lastSyncAt    DateTime?
  totalSynced   Int               @default(0)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  automations   StoreAutomation[]
  orders        StoreOrder[]

  @@index([userId])
}


model WooCommerceStore {
  id           String       @id @default(cuid())
  userId       String       @unique
  storeName    String
  storeUrl     String?
  isActive     Boolean      @default(true)
  totalSynced  Int          @default(0)
  lastSyncAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       StoreOrder[]

  @@index([userId])
}

model AutomationRule {
  id                String      @id @default(cuid())
  userId            String
  name              String
  isEnabled         Boolean     @default(true)
  triggerType       TriggerType
  triggerValue      String?
  replyType         ReplyType
  replyContent      String?
  templateId        String?
  extraInstructions String?
  humanKeywords     String[]
  pauseOnReply      Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  template          Template?   @relation(fields: [templateId], references: [id])
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isEnabled])
  @@index([triggerType])
  @@index([userId, triggerType])
}

model AIAgent {
  id                String     @id @default(cuid())
  userId            String     @unique
  isEnabled         Boolean    @default(false)
  provider          AIProvider @default(gemini)
  brandName         String?
  businessDesc      String?
  productsInfo      String?
  pricingInfo       String?
  workingHours      String?
  tone              String     @default("friendly")
  systemPrompt      String?
  pauseMinutes      Int        @default(10)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  elevenLabsEnabled Boolean    @default(false)
  elevenLabsApiKey  String?
  elevenLabsAgentId String?
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoreOrder {
  id                   String            @id @default(cuid())
  userId               String
  externalId           String
  orderNumber          String?
  customerName         String?
  customerPhone        String
  currency             String            @default("EGP")
  status               String            @default("pending")
  rawData              Json?
  contactId            String?
  createdAt            DateTime          @default(now())
  easyOrdersStoreId    String?
  orderedAt            DateTime          @default(now())
  shopifyStoreId       String?
  wooCommerceStoreId   String?
  source               OrderSource
  total                Float             @default(0)
  campaignOrder        CampaignOrder?
  easyOrdersStore      EasyOrdersStore?   @relation(fields: [easyOrdersStoreId], references: [id])
  wooCommerceStore     WooCommerceStore?  @relation(fields: [wooCommerceStoreId], references: [id], onDelete: SetNull)
  shopifyStore         ShopifyStore?     @relation(fields: [shopifyStoreId], references: [id])
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([source, externalId, userId])
  @@index([userId])
  @@index([customerPhone, userId])
  @@index([source, userId])
  @@index([orderedAt])
  @@index([wooCommerceStoreId])
}

model TrackedClick {
  id                   String    @id @default(cuid())
  userId               String
  campaignId           String
  contactId            String?
  token                String    @unique
  targetUrl            String
  clickedAt            DateTime?
  isClicked            Boolean   @default(false)
  attributionExpiresAt DateTime?
  createdAt            DateTime  @default(now())
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([contactId])
  @@index([userId, isClicked])
  @@index([attributionExpiresAt])
}

model CampaignOrder {
  id           String     @id @default(cuid())
  campaignId   String
  storeOrderId String     @unique
  revenue      Float      @default(0)
  createdAt    DateTime   @default(now())
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  storeOrder   StoreOrder @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model StoreAutomation {
  id                   String              @id @default(cuid())
  userId               String
  type                 StoreAutomationType
  isEnabled            Boolean             @default(false)
  templateId           String?
  sentCount            Int                 @default(0)
  shopifyStoreId       String?
  easyOrdersStoreId    String?
  wooCommerceStoreId   String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  easyOrdersStore      EasyOrdersStore?    @relation(fields: [easyOrdersStoreId], references: [id], onDelete: Cascade)
  shopifyStore         ShopifyStore?       @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  wooCommerceStore     WooCommerceStore?   @relation(fields: [wooCommerceStoreId], references: [id], onDelete: Cascade)
  template             Template?           @relation(fields: [templateId], references: [id])
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopifyStoreId, type])
  @@unique([easyOrdersStoreId, type])
  @@unique([wooCommerceStoreId, type])
  @@index([userId])
  @@index([shopifyStoreId])
  @@index([easyOrdersStoreId])
  @@index([wooCommerceStoreId])
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String    @default("")
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum MessageType {
  text
  image
  document
  audio
  template
}

enum MessageStatus {
  pending
  sent
  delivered
  read
  failed
}

enum MessageDirection {
  inbound
  outbound
}

enum CampaignStatus {
  draft
  scheduled
  running
  completed
  failed
}

enum UserRole {
  OWNER
  FULL_ACCESS
  CHAT_ONLY
}

enum PlanTier {
  free
  starter
  pro
  enterprise
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum QueueStatus {
  pending
  processing
  sent
  failed
  cancelled
}

enum NotificationType {
  CAMPAIGN_SUCCESS
  CAMPAIGN_FAILED
  CAMPAIGN_PARTIAL
  PLAN_LIMIT_REACHED
  NEW_MESSAGE
}

enum StoreType {
  shopify
  easyorders
  woocommerce
}

enum StoreAutomationType {
  order_confirm
  order_shipped
  promo
}

enum OrderSource {
  shopify
  easyorders
  woocommerce
}

enum TriggerType {
  KEYWORD
  FIRST_MESSAGE
  NO_REPLY
  TIME_BASED
}

enum ReplyType {
  TEXT
  TEMPLATE
  AI
}

enum AIProvider {
  gemini
  openai
}
