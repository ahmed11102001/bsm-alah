generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  text
  image
  document
  audio
  template
}

enum MessageStatus {
  pending
  sent
  delivered
  read
  failed
}

enum MessageDirection {
  inbound
  outbound
}

enum CampaignStatus {
  draft
  scheduled
  running
  completed
  failed
}

enum UserRole {
  OWNER
  FULL_ACCESS
  CHAT_ONLY
}

enum PlanTier {
  free
  starter
  pro
  enterprise
  beta
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum QueueStatus {
  pending
  processing
  sent
  failed
  cancelled
}

enum NotificationType {
  CAMPAIGN_SUCCESS
  CAMPAIGN_FAILED
  CAMPAIGN_PARTIAL
  PLAN_LIMIT_REACHED
  NEW_MESSAGE
}

// ─── Store Enums ──────────────────────────────────────────────────────────────

enum StoreType {
  shopify
  easyorders
}

enum StoreAutomationType {
  order_confirm
  order_shipped
  promo
}

enum OrderSource {
  shopify
  easyorders
}

// ─── Automation Enums ─────────────────────────────────────────────────────────

enum TriggerType {
  KEYWORD
  FIRST_MESSAGE
  NO_REPLY
  TIME_BASED
}

enum ReplyType {
  TEXT
  TEMPLATE
  AI
}

enum AIProvider {
  gemini
  openai
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  phone    String?
  password String
  image    String?
  apiKey   String? @unique

  role        UserRole @default(OWNER)
  isSuper     Boolean  @default(false)
  workspaceId String?
  inviteCode  String?  @unique
  parentId    String?

  // ─── Brand / AI settings ──────────────────────────────────────
  brandName    String?
  businessDesc String? @db.Text
  productsInfo String? @db.Text
  pricingInfo  String? @db.Text
  workingHours String?
  aiTone       String  @default("friendly")

  parent  User?  @relation("TeamHierarchy", fields: [parentId], references: [id])
  members User[] @relation("TeamHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  whatsappAccount WhatsAppAccount?
  subscription    Subscription?

  contacts        Contact[]
  audiences       Audience[]
  templates       Template[]
  campaigns       Campaign[]
  messages        Message[]
  messageQueues   MessageQueue[]
  notifications   Notification[]
  automationRules AutomationRule[]
  shopifyStore    ShopifyStore?
  easyOrdersStore EasyOrdersStore?
  aiAgent         AIAgent?

  storeOrders      StoreOrder[]
  trackedClicks    TrackedClick[]
  storeAutomations StoreAutomation[]

  @@index([email])
  @@index([workspaceId])
  @@index([parentId])
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   PlanTier           @default(free)
  status SubscriptionStatus @default(active)

  campaignsUsedThisMonth Int      @default(0)
  periodResetAt          DateTime @default(now())
  currentPeriodStart     DateTime @default(now())
  currentPeriodEnd       DateTime @default(dbgenerated("NOW() + INTERVAL '100 years'"))

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([plan])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model WhatsAppAccount {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken   String @db.Text
  phoneNumberId String
  wabaId        String @unique

  messagingTier  Int      @default(1)
  dailySentCount Int      @default(0)
  dailyResetAt   DateTime @default(now())

  backoffUntil DateTime?
  backoffCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messageQueues MessageQueue[]
}

model MessageQueue {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  whatsappAccountId String
  whatsappAccount   WhatsAppAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  phoneNumberId     String

  toPhone   String
  contactId String?

  messageType  String  @default("template")
  templateName String?
  templateLang String  @default("ar")
  templateVars Json?
  content      String? @db.Text

  campaignId String?

  status      QueueStatus @default(pending)
  scheduledAt DateTime    @default(now())
  processedAt DateTime?
  sentAt      DateTime?

  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  nextRetryAt DateTime?

  whatsappMsgId     String?
  error             String? @db.Text
  existingMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([phoneNumberId, status])
  @@index([campaignId])
  @@index([userId, status])
  @@index([status, nextRetryAt])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type   NotificationType
  title  String
  body   String           @db.Text
  isRead Boolean          @default(false)
  link   String?
  meta   Json?

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model Audience {
  id   String @id @default(cuid())
  name String
  type String @default("excel")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contacts Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id    String  @id @default(cuid())
  phone String
  name  String?
  notes String? @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  audienceId String?
  audience   Audience? @relation(fields: [audienceId], references: [id], onDelete: SetNull)

  messages Message[]

  isPinned      Boolean   @default(false)
  isArchived    Boolean   @default(false)
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  deletedAt     DateTime?

  // ─── Voice Agent ──────────────────────────────────────────────
  voiceAgentEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, userId])
  @@index([userId])
  @@index([phone])
  @@index([lastMessageAt])
}

model Template {
  id      String @id @default(cuid())
  metaId  String
  name    String
  content String @db.Text

  language String @default("ar")
  category String @default("MARKETING")
  status   String @default("pending")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  campaigns      Campaign[]
  automationRules AutomationRule[]
  storeAutomations StoreAutomation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([metaId, userId])
  @@index([userId])
  @@index([status])
}

model Campaign {
  id     String         @id @default(cuid())
  name   String
  status CampaignStatus @default(draft)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  messages Message[]

  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  failedCount    Int @default(0)
  totalQueued    Int @default(0)
  queuedCount    Int @default(0)

  // ─── Revenue Attribution ───────────────────────────────────────
  trackedUrl   String? @db.Text  // الرابط الأصلي اللي حطه العميل
  revenue      Float   @default(0)
  ordersCount  Int     @default(0)

  campaignOrders CampaignOrder[]

  startedAt   DateTime?
  completedAt DateTime?
  scheduledAt DateTime? @map("scheduled_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model Message {
  id String @id @default(cuid())

  content String? @db.Text

  type      MessageType      @default(text)
  status    MessageStatus    @default(pending)
  direction MessageDirection @default(outbound)

  whatsappId String? @unique

  mediaUrl String? @db.Text
  error    String?
  reactions Json?  @default("[]")

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contactId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@index([contactId, createdAt])
}

model WebhookLog {
  id String @id @default(cuid())

  userId String?

  payload   String  @db.Text
  processed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([processed])
  @@index([createdAt])
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  brandName String
  phone     String
  rating    Int
  content   String  @db.Text
  approved  Boolean @default(false)
  userId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved])
  @@index([createdAt])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("percent")
  discountValue Float
  maxUses       Int       @default(1)
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([active])
}

model ShopifyStore {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  shop          String   @unique
  accessToken   String   @db.Text
  scope         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders         StoreOrder[]
  automations    StoreAutomation[]

  @@index([shop])
}

model EasyOrdersStore {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  storeName     String
  apiKey        String   @db.Text
  webhookSecret String   @db.Text

  isActive      Boolean  @default(true)

  lastSyncAt    DateTime?
  totalSynced   Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        StoreOrder[]
  automations   StoreAutomation[]

  @@index([userId])
}

// ─── Automation ───────────────────────────────────────────────────────────────

model AutomationRule {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  isEnabled Boolean @default(true)

  // ─── Trigger ──────────────────────────────────────────────────
  triggerType  TriggerType
  triggerValue String?     // keyword text | عدد الأيام لـ NO_REPLY

  // ─── Reply ────────────────────────────────────────────────────
  replyType         ReplyType
  replyContent      String?   @db.Text
  templateId        String?
  template          Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  extraInstructions String?   @db.Text

  // ─── Human takeover ───────────────────────────────────────────
  humanKeywords String[]
  pauseOnReply  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isEnabled])
  @@index([triggerType])
  @@index([userId, triggerType])
}

model AIAgent {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isEnabled Boolean    @default(false)
  provider  AIProvider @default(gemini)

  // ─── Brand context ────────────────────────────────────────────
  brandName    String?
  businessDesc String? @db.Text
  productsInfo String? @db.Text
  pricingInfo  String? @db.Text
  workingHours String?
  tone         String  @default("friendly")

  // ─── Custom system prompt ─────────────────────────────────────
  systemPrompt String? @db.Text

  // ─── Human takeover pause (minutes) ──────────────────────────
  pauseMinutes Int @default(10)

  // ─── ElevenLabs Voice Agent ───────────────────────────────────
  elevenLabsEnabled  Boolean @default(false)
  elevenLabsApiKey   String? @db.Text
  elevenLabsAgentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Store Orders ─────────────────────────────────────────────────────────────
// كل أوردر بييجي من Shopify أو EasyOrders يتحفظ هنا

model StoreOrder {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  source      OrderSource
  externalId  String       // order id في Shopify أو EasyOrders
  orderNumber String?      // رقم الأوردر المعروض للعميل

  customerPhone String
  customerName  String?
  total         Float    @default(0)
  currency      String   @default("EGP")
  status        String   @default("pending")
    rawData Json? 
    contactId String? 
  // العلاقة بالمتجر — واحد من الاتنين بس بيكون موجود
  shopifyStoreId    String?
  shopifyStore      ShopifyStore?    @relation(fields: [shopifyStoreId], references: [id], onDelete: SetNull)
  easyOrdersStoreId String?
  easyOrdersStore   EasyOrdersStore? @relation(fields: [easyOrdersStoreId], references: [id], onDelete: SetNull)

  // لو الأوردر ده اتنسب لحملة
  campaignOrder CampaignOrder?

  orderedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([source, externalId, userId])
  @@index([userId])
  @@index([customerPhone, userId])
  @@index([source, userId])
  @@index([orderedAt])
}

// ─── Tracked Clicks ───────────────────────────────────────────────────────────
// كل ضغطة على رابط متتبع في حملة

model TrackedClick {
  id String @id @default(cuid())

  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String
  contactId  String?

  // الـ token الفريد اللي بيتولد لكل كونتاكت في كل حملة
  token     String   @unique
  // الرابط الأصلي اللي هيتحول إليه
  targetUrl String   @db.Text

  clickedAt DateTime?
  isClicked Boolean   @default(false)

  // attribution window: 48 ساعة من الكليك
  attributionExpiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([contactId])
  @@index([userId, isClicked])
  @@index([attributionExpiresAt])
}

// ─── Campaign Orders ──────────────────────────────────────────────────────────
// الأوردرات اللي اتنسبت لحملة معينة (نتيجة Attribution)

model CampaignOrder {
  id String @id @default(cuid())

  campaignId   String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  storeOrderId String     @unique
  storeOrder   StoreOrder @relation(fields: [storeOrderId], references: [id], onDelete: Cascade)

  revenue Float @default(0)

  createdAt DateTime @default(now())

  @@index([campaignId])
}

// ─── Store Automations ────────────────────────────────────────────────────────
// إعدادات الأتمتة لكل متجر (تأكيد أوردر / شحن / عروض)

model StoreAutomation {
  id     String              @id @default(cuid())
  userId String
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      StoreAutomationType
  isEnabled Boolean             @default(false)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // إحصائية: كم رسالة اتبعتت من خلال الأتمتة دي
  sentCount Int @default(0)

  // العلاقة بالمتجر — واحد من الاتنين
  shopifyStoreId    String?
  shopifyStore      ShopifyStore?    @relation(fields: [shopifyStoreId], references: [id], onDelete: Cascade)
  easyOrdersStoreId String?
  easyOrdersStore   EasyOrdersStore? @relation(fields: [easyOrdersStoreId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // كل متجر ما يكونش عنده أكتر من automation من نفس النوع
  @@unique([shopifyStoreId, type])
  @@unique([easyOrdersStoreId, type])
  @@index([userId])
  @@index([shopifyStoreId])
  @@index([easyOrdersStoreId])
}

// المقالات
model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String    @default("")
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
