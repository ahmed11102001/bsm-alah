# ==============================================================================
# WhatsPro — Environment Variables
# ==============================================================================
# 1. انسخ الملف ده: cp .env.example .env.local
# 2. اعبي القيم المطلوبة (required)
# 3. المتغيرات الاختيارية (optional) عندها قيم افتراضية معقولة
# ==============================================================================


# ── NextAuth ────────────────────────────────────────────────────────────────────
# REQUIRED

# رابط الموقع — محتاج يكون صح عشان redirects بعد login تشتغل
NEXTAUTH_URL=http://localhost:3000

# سيكريت عشوائي — ولّده بـ: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── تشفير البيانات الحساسة في DB (AES-256-GCM) ──────────────────────────────
# أنشئها بـ: openssl rand -hex 32
# مطلوبة — بدونها التطبيق مش هيشتغل
ENCRYPTION_KEY=


# ── Database (PostgreSQL) ────────────────────────────────────────────────────────
# REQUIRED
# Neon: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# ── WhatsApp / Meta ──────────────────────────────────────────────────────────────
# REQUIRED
# من Meta for Developers → App → Settings → Basic
NEXT_PUBLIC_META_APP_ID=               # App ID من Meta App Dashboard
NEXT_PUBLIC_META_CONFIG_ID=            # Configuration ID من Facebook Login for Business → Configurations (Embedded Signup)
META_APP_SECRET=                       # App Secret — SERVER-SIDE ONLY — لا تضيفه NEXT_PUBLIC_
                                        # ده نفس السيكريت المستخدم في التحقق من توقيع الـ Webhooks
                                        # (WHATSAPP_APP_SECRET اسم قديم/deprecated، لسه مقبول كـ fallback بس مش موثّق هنا عمدًا)
NEXT_PUBLIC_GRAPH_API_VERSION=v22.0    # إصدار Graph API المستخدم

# من Meta for Developers → App → WhatsApp → Configuration
WHATSAPP_VERIFY_TOKEN=        # أي نص سري بتختاره إنت لتفعيل الـ Webhook


# ── Cloudinary (رفع الصور والملفات) ─────────────────────────────────────────────
# REQUIRED
# https://cloudinary.com → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=     # اعمل unsigned preset من Settings → Upload


# ── Resend (إرسال الإيميلات) ────────────────────────────────────────────────────
# REQUIRED
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=

# OPTIONAL — القيمة الافتراضية: "واتس برو <no-reply@whatspro.app>"
# لازم يكون domain محقق على Resend
# EMAIL_FROM=WhatsPro <no-reply@yourdomain.com>


# ── Upstash Redis (Rate Limiting) ────────────────────────────────────────────────
# REQUIRED في Production — اختياري في Development (بيستخدم ephemeral cache)
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── Inngest (Background Jobs) ────────────────────────────────────────────────────
# REQUIRED في Production
# https://app.inngest.com → Your App → API Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# ── AI Providers ─────────────────────────────────────────────────────────────────
# OPTIONAL — حسب الـ provider اللي اختاره كل يوزر في الـ AI Agent settings

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OPTIONAL — القيمة الافتراضية: gemini-1.5-flash
# GEMINI_MODEL=gemini-1.5-flash

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# ── Shopify Integration ───────────────────────────────────────────────────────────
# REQUIRED لو هتفعّل Shopify App
# https://partners.shopify.com → Apps → Create App
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/shopify/callback


# ── Frontend Public Vars ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_* بتتبعت للمتصفح — متحطش فيها سيكريتس

# OPTIONAL — رابط الموقع للاستخدام في الـ frontend
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# رقم واتساب السيلز (بدون + أو مسافات) — يظهر في الـ AI Widget على اللاندينج
NEXT_PUBLIC_SALES_WHATSAPP=YOUR_SALES_NUMBER_HERE

# OPTIONAL — Meta Pixel ID لتتبع الإعلانات
# NEXT_PUBLIC_META_PIXEL_ID=


# ── Queue Tuning ──────────────────────────────────────────────────────────────────
# OPTIONAL — كلهم عندهم قيم افتراضية مناسبة

# التأخير بين كل رسالة والتانية (milliseconds) — الافتراضي: 350
# QUEUE_DELAY_MS=350

# الوقت المتاح للـ queue قبل ما Vercel يقتل الـ function (ms) — الافتراضي: 8000
# QUEUE_BUDGET_MS=8000

# خطوات الـ backoff بالثواني عند rate limit من واتساب — الافتراضي: 60,300,900,3600
# QUEUE_BACKOFF_STEPS=60,300,900,3600

# حدود WhatsApp Messaging Tiers اليومية — الافتراضيات من Meta
# TIER_1_DAILY_LIMIT=1000
# TIER_2_DAILY_LIMIT=10000
# TIER_3_DAILY_LIMIT=100000

# حجم الـ batch لكل Tier
# TIER_1_BATCH_SIZE=10
# TIER_2_BATCH_SIZE=30
# TIER_3_BATCH_SIZE=80
# TIER_4_BATCH_SIZE=150

# ── Developer Portal ─────────────────────────────────────────────────────────────
# REQUIRED — سيكريت JWT منفصل لـ Developer Portal
# ولّده بـ: openssl rand -hex 32
# لو مش موجود بيستخدم NEXTAUTH_SECRET كـ fallback
DEV_JWT_SECRET=

# ── Fawaterak (بوابة الدفع) ───────────────────────────────────────────────────
# REQUIRED — مفتاح Bearer للـ Authorization header في كل طلب API

# من: Dashboard → Integration → Get API key
FAWATERAK_API_KEY=
FAWATERAK_VENDOR_KEY=
