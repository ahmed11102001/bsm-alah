# ==================== NEXTAUTH ====================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-generate-one

# استخدم http://localhost:3000 في development
# استخدم https://yourdomain.com في production
NEXTAUTH_URL=http://localhost:3000

# ==================== DATABASE ====================
# Format: postgresql://user:password@host:port/database
# استخدم Neon PostgreSQL (https://neon.tech)
DATABASE_URL=postgresql://user:password@db.neon.tech:5432/database

# ==================== WHATSAPP API ====================
# من https://developers.facebook.com/
WHATSAPP_API_KEY=your-whatsapp-api-key-here
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id-here

# (Optional) الـ webhook secret للـ Webhook verification
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret

# ==================== VERCEL (Production) ====================
# Vercel بتعرّف هذا تلقائياً لكن إذا محتاج override:
# NODE_ENV=production
